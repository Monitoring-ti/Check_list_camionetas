# Copiar a .env.local y completar con valores de Supabase → Settings → API
# NUNCA subir .env.local a git. NUNCA usar service_role en el frontend.
# Mismo proyecto que consulta_camionetas / Monitoring.

NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
# Preferir anon key (JWT). También acepta publishable key.
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...tu-anon-key...
# Alternativa (Supabase nuevo):
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
