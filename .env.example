# Copiar a .env.local y completar con valores de Supabase → Settings → API
# NUNCA subir .env.local a git. NUNCA usar service_role en el frontend.
# Mismo proyecto que consulta_camionetas / Monitoring.

NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
# Preferir anon key (JWT). También acepta publishable key.
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...tu-anon-key...
# Alternativa (Supabase nuevo):
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Alertas No apta (solo servidor — configurar en Vercel / .env.local)
# Requiere SUPABASE_SERVICE_ROLE_KEY para verificar la inspección guardada.
SUPABASE_SERVICE_ROLE_KEY=eyJ...tu-service-role-key...

# Correo vía Resend (https://resend.com)
RESEND_API_KEY=re_...
ALERT_EMAIL=ti.soporte@monitoring.cl
# RESEND_FROM=Monitoring Checklist <alertas@monitoring.cl>

# Opcional: webhook (Slack, Teams, Make, n8n, etc.)
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/...
